# Copy to .env.local and fill in. .env.local is gitignored — never commit secrets.
# The app runs without these (offline mock provider); they unlock the live
# Inworld Realtime voice/text session.

# Inworld API key (Inworld Portal -> Settings -> API Keys). Used server-side only.
INWORLD_API_KEY=your-inworld-api-key

# The LLM "brain": an Inworld router id (preferred) or a concrete model id.
# Create a router in the Inworld Portal (see README) and put its id here.
INWORLD_REALTIME_MODEL=inworld/your-router-name

# Voice + speech stack. Voice is an Inworld voice name (see Portal voice library).
INWORLD_REALTIME_VOICE=Ashley

# Optional — these have sensible defaults in code; override only if needed.
# INWORLD_STT_MODEL=inworld/inworld-stt-1
# INWORLD_TTS_MODEL=inworld-tts-2

# Google Gemini API key — unlocks the generate_image tool (assistant generates
# an image with "Nano Banana" and drops it onto the canvas). Used server-side
# only. Omit to disable the tool. Get one at https://aistudio.google.com/apikey
GEMINI_API_KEY=your-gemini-api-key

# Optional image model override. gemini-2.5-flash-image is "Nano Banana";
# gemini-3.1-flash-image ("Nano Banana 2") is newer/higher-fidelity.
# GEMINI_IMAGE_MODEL=gemini-2.5-flash-image

# Web search — unlocks the web_search tool (assistant looks things up live).
# Provide ONE: Tavily is preferred (returns an AI-ready answer + sources);
# Brave is the fallback (web results only). Used server-side only; omit both to
# disable the tool.
#   Tavily key: https://app.tavily.com  |  Brave key: https://api-dashboard.search.brave.com
TAVILY_API_KEY=your-tavily-api-key
# BRAVE_API_KEY=your-brave-api-key

# Website screenshots — unlocks the screenshot_website tool (assistant captures a
# live web page and drops it on the canvas via thum.io). Used server-side only;
# omit to disable the tool. Get a key at https://www.thum.io
THUM_IO_KEY=your-thum-io-key
